generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String      @id @default(uuid()) @db.Uuid
  telegramId         BigInt      @unique @map("telegram_id")
  telegramUsername   String      @map("telegram_username")
  googleRefreshToken String?     @map("google_refresh_token")
  googleCalendarId   String?     @map("google_calendar_id")
  timezone           String      @default("Asia/Singapore")
  briefingEnabled    Boolean     @default(false) @map("briefing_enabled")
  briefingTime       String?     @map("briefing_time")
  aiProvider         AiProvider? @map("ai_provider")
  aiApiKey           String?     @map("ai_api_key")
  aiModel            String?     @map("ai_model")
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  categories Category[]
  items      Item[]

  @@map("users")
}

enum AiProvider {
  openai
  anthropic
  gemini
  openrouter
}

enum ItemStatus {
  pending
  in_progress
  done
}

enum Priority {
  low
  medium
  high
}

enum RecurringType {
  none
  daily
  weekly
  monthly
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  color     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  items Item[]

  @@unique([userId, name])
  @@map("categories")
}

model Item {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  categoryId  String        @map("category_id") @db.Uuid
  title       String
  description String?
  status      ItemStatus    @default(pending)
  priority    Priority      @default(medium)
  dueDate     String?       @map("due_date")
  dueTime     String?       @map("due_time")
  remindAt    DateTime?     @map("remind_at") @db.Timestamptz
  recurring   RecurringType @default(none)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("items")
}
